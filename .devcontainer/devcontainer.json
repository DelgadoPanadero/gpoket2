// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/docker-existing-dockerfile
{
    "name": "Existing Docker Compose",
    "dockerComposeFile": [
        "../docker-compose.yml"
    ],
    "service": "devcontainer",
    "workspaceFolder": "/home/gpoket2",
    //"remoteUser": "${localEnv:USER}",
    "remoteUser": "${localEnv:USER}",
    "mounts": [
        "source=${localEnv:HOME}/.claude.json,target=/home/${localEnv:USER}/.claude.json,type=bind,consistency=cached",
        "source=${localEnv:HOME}/.claude,target=/home/${localEnv:USER}/.claude,type=bind,consistency=cached",
        "source=${localEnv:HOME}/.local/share/claude,target=/home/${localEnv:USER}/.local/share/claude,type=bind,readonly,consistency=cached"
    ],

    // Symlink the mounted binary into PATH the first time the container starts.
    "postCreateCommand": "sudo ln -sf /home/${localEnv:USER}/.local/share/claude/versions/$(ls /home/${localEnv:USER}/.local/share/claude/versions | sort -V | tail -1) /usr/local/bin/claude",

    "customizations": {
        "vscode": {
            "settings": {
                "python.languageServer": "Default",
                "cmake.ignoreCMakeListsMissing": true,
                "python.defaultInterpreterPath": "/home/gpoket2/.venv/bin/python",
                "python.linting.enabled": true,
                "python.linting.pylintEnabled": false,
                "python.linting.ruffEnabled": true,
                "python.linting.ruffPath": "/home/gpoket2/.venv/bin/ruff",
                "[python]": {
                    "editor.rulers": [80]
                }
            }
        },
        "extensions": [
            "ms-python.python",
            "ms-python.vscode-pylance",
            "ms-toolsai.jupyter",
            "charliermarsh.ruff-vscode",
            "anthropics.claude-code",
            "github.vscode-github-actions",
            "tamasfe.even-better-toml"
        ]
    }
}
